# Copy this file to .dev.vars and fill in the values.
# .dev.vars is gitignored — never commit real secrets.

# JWT signing secret — use any random string locally
JWT_SECRET=dev-secret-not-for-production-use-only

# Set to true to enable development shortcuts (e.g. skip checks)
DEV_MODE=true

# Generated by: npx tsx scripts/generate-vapid-keys.ts
VAPID_PRIVATE_KEY=<your-generated-vapid-private-key>

# From @BotFather on Telegram after creating a bot
TELEGRAM_BOT_TOKEN=<your-telegram-bot-token>

# Any random secret used to validate incoming Telegram webhook requests
TELEGRAM_WEBHOOK_SECRET=<your-random-webhook-secret>
